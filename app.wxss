page {
  background: #F8F9FA;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.container {
  padding: 24rpx;
  min-height: 100vh;
}

/* 通用卡片 */
.card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 工具卡片 */
.tool-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(108, 92, 231, 0.08);
  display: flex;
  align-items: center;
  transition: all 0.3s ease;
}

.tool-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(108, 92, 231, 0.12);
}

.tool-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.tool-info {
  flex: 1;
}

.tool-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 8rpx;
}

.tool-desc {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.5;
}

.tool-arrow {
  font-size: 28rpx;
  color: #CCCCCC;
  margin-left: 16rpx;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.tag-red { background: #FFE5E5; color: #E74C3C; }
.tag-orange { background: #FFF3E0; color: #F39C12; }
.tag-blue { background: #E3F2FD; color: #3498DB; }
.tag-green { background: #E8F5E9; color: #27AE60; }
.tag-purple { background: #F3E5F5; color: #9B59B6; }

/* 按钮 */
.btn-primary {
  background: linear-gradient(135deg, #6C5CE7, #A29BFE);
  color: #FFFFFF;
  border-radius: 50rpx;
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 20rpx rgba(108, 92, 231, 0.4);
  text-align: center;
}

.btn-primary::after { border: none; }

.btn-secondary {
  background: #F8F9FA;
  color: #6C5CE7;
  border-radius: 50rpx;
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: 2rpx solid #6C5CE7;
}

.btn-secondary::after { border: none; }

/* 输入框 */
.input-box {
  background: #F8F9FA;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #2D3436;
  margin-bottom: 24rpx;
}

/* 结果展示区 */
.result-box {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-top: 24rpx;
  border: 2rpx solid #F0F0F0;
}

.result-title {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #CCCCCC;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: #F0F0F0;
  margin: 24rpx 0;
}
