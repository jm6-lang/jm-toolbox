.page { padding: 24rpx; background: #f5f6fa; min-height: 100vh; }
.card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 24rpx; }
.upload-area { display: flex; flex-direction: column; align-items: center; padding: 48rpx; border: 2rpx dashed #ddd; border-radius: 12rpx; }
.upload-icon { font-size: 64rpx; margin-bottom: 12rpx; }
.upload-text { font-size: 28rpx; color: #999; }
.quality-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx; }
.quality-label { font-size: 28rpx; color: #333; white-space: nowrap; }
.quality-slider { flex: 1; }
.stats { display: flex; align-items: center; justify-content: center; gap: 16rpx; padding: 16rpx 0; margin-bottom: 16rpx; }
.stat { font-size: 26rpx; color: #666; }
.stat-arrow { color: #999; }
.stat.result { color: #6C5CE7; font-weight: 600; }
.image-list { margin-bottom: 16rpx; }
.image-item { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.image-thumb { width: 80rpx; height: 80rpx; border-radius: 8rpx; margin-right: 16rpx; }
.image-info { flex: 1; display: flex; align-items: center; gap: 12rpx; }
.image-size { font-size: 26rpx; color: #333; }
.image-ratio { font-size: 24rpx; color: #999; }
.ratio-good { color: #27AE60; font-weight: 600; }
.btn-sm { font-size: 24rpx; padding: 8rpx 20rpx; background: #6C5CE7; color: #fff; border-radius: 8rpx; line-height: 1.4; }
.btn-row { display: flex; gap: 16rpx; }
.btn-compress { flex: 1; background: #6C5CE7; color: #fff; border-radius: 12rpx; font-size: 30rpx; padding: 20rpx; }
.btn-save-all { flex: 1; background: #27AE60; color: #fff; border-radius: 12rpx; font-size: 30rpx; padding: 20rpx; }
