<view class="page">
  <view class="card">
    <view class="upload-area" bindtap="chooseImages">
      <text class="upload-icon">📷</text>
      <text class="upload-text">选择图片（最多9张）</text>
    </view>
  </view>

  <view class="card" wx:if="{{images.length > 0}}">
    <view class="quality-row">
      <text class="quality-label">压缩质量</text>
      <slider class="quality-slider" min="10" max="100" value="{{quality}}" 
        activeColor="#6C5CE7" block-size="20" bindchange="onQualityChange" show-value />
    </view>

    <view class="stats">
      <text class="stat">原始: {{totalOriginal > 1048576 ? (totalOriginal/1048576).toFixed(2) : (totalOriginal/1024).toFixed(1)}}{{totalOriginal > 1048576 ? 'MB' : 'KB'}}</text>
      <text class="stat-arrow">→</text>
      <text class="stat result">压缩后: {{totalCompressed > 1048576 ? (totalCompressed/1048576).toFixed(2) : (totalCompressed/1024).toFixed(1)}}{{totalCompressed > 1048576 ? 'MB' : 'KB'}}</text>
    </view>

    <view class="image-list">
      <view class="image-item" wx:for="{{images}}" wx:key="index">
        <image class="image-thumb" src="{{item.compressed ? item.compressedPath : item.path}}" mode="aspectFill" />
        <view class="image-info">
          <text class="image-size">{{item.size > 1048576 ? (item.size/1048576).toFixed(2) : (item.size/1024).toFixed(1)}}{{item.size > 1048576 ? 'MB' : 'KB'}}</text>
          <text class="image-ratio {{item.ratio && item.ratio.indexOf('-') === 0 ? 'ratio-good' : ''}}" wx:if="{{item.compressed}}">{{item.ratio}}</text>
        </view>
        <button class="btn-sm" wx:if="{{item.compressed}}" data-index="{{index}}" bindtap="saveImage">保存</button>
      </view>
    </view>

    <view class="btn-row">
      <button class="btn-compress" bindtap="compressAll" disabled="{{processing}}">
        {{processing ? '压缩中...' : '一键压缩'}}
      </button>
      <button class="btn-save-all" bindtap="saveAll">全部保存</button>
    </view>
  </view>
</view>
