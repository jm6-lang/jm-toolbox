.page { padding: 24rpx; background: #f5f6fa; min-height: 100vh; }
.upload-area { background: #fff; border-radius: 16rpx; padding: 48rpx; display: flex; flex-direction: column; align-items: center; margin-bottom: 24rpx; min-height: 300rpx; justify-content: center; border: 2rpx dashed #ddd; }
.upload-icon { font-size: 64rpx; margin-bottom: 12rpx; }
.upload-text { font-size: 28rpx; color: #999; }
.preview-img { width: 100%; max-height: 400rpx; border-radius: 12rpx; }
.section-title { font-size: 30rpx; font-weight: 600; color: #2d3436; margin-bottom: 16rpx; }
.color-list { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 24rpx; }
.color-items { display: flex; flex-direction: column; gap: 12rpx; }
.color-item { display: flex; align-items: center; padding: 12rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.color-item:last-child { border: none; }
.color-swatch { width: 60rpx; height: 60rpx; border-radius: 12rpx; margin-right: 16rpx; border: 1rpx solid #eee; }
.color-info { flex: 1; }
.color-name { font-size: 28rpx; color: #333; display: block; }
.color-hex { font-size: 24rpx; color: #999; }
.color-percent { font-size: 24rpx; color: #6C5CE7; font-weight: 600; }
.picked-detail { background: #fff; border-radius: 16rpx; padding: 24rpx; }
.picked-header { display: flex; align-items: center; gap: 20rpx; margin-bottom: 20rpx; }
.picked-swatch { width: 100rpx; height: 100rpx; border-radius: 16rpx; border: 2rpx solid #eee; }
.picked-info { flex: 1; }
.picked-name { font-size: 30rpx; font-weight: 600; color: #333; display: block; }
.picked-hex { font-size: 28rpx; color: #666; display: block; margin-top: 4rpx; }
.picked-rgb { font-size: 26rpx; color: #999; display: block; }
.copy-btns { display: flex; gap: 16rpx; }
.copy-btn { flex: 1; background: #6C5CE7; color: #fff; border-radius: 12rpx; font-size: 28rpx; padding: 16rpx; }
