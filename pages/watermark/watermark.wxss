/* pages/watermark/watermark.wxss */
.page { padding: 24rpx; background: #F8F9FA; min-height: 100vh; }
.upload-area { background: #FFF; border-radius: 24rpx; height: 400rpx; display: flex; align-items: center; justify-content: center; margin-bottom: 24rpx; border: 2rpx dashed #E0E0E0; overflow: hidden; }
.placeholder { display: flex; flex-direction: column; align-items: center; color: #999; }
.icon { font-size: 80rpx; margin-bottom: 16rpx; }
.text { font-size: 28rpx; }
.preview-img { width: 100%; height: 100%; }
.tips-bar { background: #FFF9E6; border-radius: 16rpx; padding: 24rpx 30rpx; display: flex; align-items: center; margin-bottom: 24rpx; }
.tips-icon { font-size: 32rpx; margin-right: 12rpx; }
.tips-text { flex: 1; font-size: 24rpx; color: #B8860B; }
.tips-arrow { font-size: 28rpx; color: #B8860B; }
.card { background: #FFF; border-radius: 24rpx; padding: 30rpx; margin-bottom: 24rpx; }
.card-title { font-size: 30rpx; font-weight: 600; color: #2D3436; margin-bottom: 24rpx; padding-bottom: 16rpx; border-bottom: 1rpx solid #F0F0F0; }
.setting-item { margin-bottom: 20rpx; }
.setting-label { font-size: 26rpx; color: #666; display: block; margin-bottom: 12rpx; }
.picker-row { background: #F8F9FA; padding: 20rpx 24rpx; border-radius: 12rpx; display: flex; justify-content: space-between; font-size: 28rpx; }
.arrow { color: #999; }
.btn-primary { background: linear-gradient(135deg, #3498DB, #74B9FF); color: #FFF; border-radius: 50rpx; padding: 28rpx; font-size: 30rpx; font-weight: 600; border: none; box-shadow: 0 6rpx 24rpx rgba(52, 152, 219, 0.4); }
.btn-primary::after { border: none; }
.result-card { background: #FFF; border-radius: 24rpx; padding: 30rpx; margin-top: 24rpx; }
.result-img { width: 100%; border-radius: 16rpx; margin-bottom: 20rpx; }
.btn-save, .btn-share { width: 100%; padding: 24rpx; border-radius: 50rpx; font-size: 26rpx; font-weight: 600; text-align: center; border: none; margin-bottom: 16rpx; }
.btn-save { background: linear-gradient(135deg, #3498DB, #74B9FF); color: #FFF; }
.btn-share { background: #F0F0F0; color: #666; }
.btn-save::after, .btn-share::after { border: none; }
