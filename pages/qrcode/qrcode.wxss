.page { padding: 24rpx; background: #f5f6fa; min-height: 100vh; }
.tabs { display: flex; background: #fff; border-radius: 16rpx; margin-bottom: 24rpx; overflow: hidden; }
.tab { flex: 1; text-align: center; padding: 20rpx 0; font-size: 28rpx; color: #666; transition: all .2s; }
.tab-active { color: #6C5CE7; font-weight: 600; background: #f0eeff; }
.input-section { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 24rpx; }
.input-area { width: 100%; min-height: 120rpx; font-size: 28rpx; line-height: 1.6; }
.char-count { font-size: 24rpx; color: #999; text-align: right; display: block; margin-top: 8rpx; }
.form-item { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.form-item:last-child { border: none; }
.form-label { width: 140rpx; font-size: 28rpx; color: #333; }
.form-input { flex: 1; font-size: 28rpx; }
.picker { color: #333; }
.settings-row { display: flex; background: #fff; border-radius: 16rpx; padding: 20rpx 24rpx; margin-bottom: 24rpx; justify-content: space-between; }
.setting-item { display: flex; align-items: center; gap: 8rpx; }
.setting-label { font-size: 24rpx; color: #999; }
.setting-val { font-size: 26rpx; color: #333; }
.color-input { width: 100rpx; font-size: 24rpx; border: 1rpx solid #eee; border-radius: 8rpx; padding: 4rpx 8rpx; text-align: center; }
.btn-generate { background: #6C5CE7; color: #fff; border-radius: 16rpx; font-size: 32rpx; padding: 24rpx; margin-top: 16rpx; }
.result-section { margin-top: 32rpx; text-align: center; }
.qr-preview { margin: 0 auto; display: flex; align-items: center; justify-content: center; border-radius: 8rpx; border: 2rpx solid #eee; }
.qr-placeholder { font-size: 48rpx; font-weight: bold; opacity: 0.3; }
.btn-save { margin-top: 24rpx; background: #27AE60; color: #fff; border-radius: 16rpx; font-size: 28rpx; padding: 20rpx; }
