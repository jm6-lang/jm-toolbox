<view class="page">
  <view class="tabs">
    <view class="tab {{activeTab === index ? 'tab-active' : ''}}" wx:for="{{tabs}}" wx:key="index"
      data-index="{{index}}" bindtap="onTabChange">
      {{item}}
    </view>
  </view>

  <view class="input-section" wx:if="{{activeTab === 0}}">
    <textarea class="input-area" placeholder="输入要编码的文字内容" 
      value="{{inputText}}" bindinput="onInputChange" maxlength="500" auto-height />
    <text class="char-count">{{charCount}}/500</text>
  </view>

  <view class="input-section" wx:if="{{activeTab === 1}}">
    <textarea class="input-area" placeholder="输入网址（如 www.example.com）" 
      value="{{inputText}}" bindinput="onInputChange" maxlength="500" auto-height />
    <text class="char-count">{{charCount}}/500</text>
  </view>

  <view class="input-section" wx:if="{{activeTab === 2}}">
    <view class="form-item">
      <text class="form-label">WiFi名称</text>
      <input class="form-input" placeholder="输入WiFi名称" value="{{wifiSSID}}" 
        bindinput="onWifiSSIDInput" />
    </view>
    <view class="form-item">
      <text class="form-label">密码</text>
      <input class="form-input" placeholder="输入WiFi密码" password value="{{wifiPassword}}" 
        bindinput="onWifiPasswordInput" />
    </view>
    <view class="form-item">
      <text class="form-label">加密方式</text>
      <picker range="{{encryptionOptions}}" value="{{encryptionIndex}}" bindchange="onEncryptionChange">
        <view class="form-input picker">{{encryptionOptions[encryptionIndex]}}</view>
      </picker>
    </view>
  </view>

  <view class="settings-row">
    <view class="setting-item">
      <text class="setting-label">尺寸</text>
      <picker range="{{sizeLabels}}" value="{{sizeIndex}}" bindchange="onSizeChange">
        <view class="setting-val">{{sizeLabels[sizeIndex]}}</view>
      </picker>
    </view>
    <view class="setting-item">
      <text class="setting-label">前景色</text>
      <input class="color-input" type="text" value="{{fgColor}}" bindinput="onFgColorInput" />
    </view>
    <view class="setting-item">
      <text class="setting-label">背景色</text>
      <input class="color-input" type="text" value="{{bgColor}}" bindinput="onBgColorInput" />
    </view>
  </view>

  <button class="btn-generate" bindtap="generateQR">生成二维码</button>

  <view class="result-section" wx:if="{{generated}}">
    <view class="qr-preview" style="width:{{qrSizePx}}px;height:{{qrSizePx}}px;background:{{bgColor}};">
      <text class="qr-placeholder" style="color:{{fgColor}};">QR</text>
    </view>
    <button class="btn-save" bindtap="saveQR">保存到相册</button>
  </view>
</view>
