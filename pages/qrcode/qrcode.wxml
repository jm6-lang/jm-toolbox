<view class="page">
  <view class="tabs">
    <view class="tab {{activeTab === index ? 'tab-active' : ''}}" wx:for="{{tabs}}" wx:key="index"
      data-index="{{index}}" bindtap="onTabChange">
      {{item}}
    </view>
  </view>

  <!-- 文字/网址输入 -->
  <view class="input-section" wx:if="{{activeTab < 2}}">
    <textarea class="input-area" placeholder="{{activeTab === 0 ? '输入要编码的文字内容' : '输入网址（如 www.example.com）'}}" 
      value="{{inputText}}" bindinput="onInputChange" maxlength="500" auto-height />
    <text class="char-count">{{inputText.length}}/500</text>
  </view>

  <!-- WiFi输入 -->
  <view class="input-section" wx:if="{{activeTab === 2}}">
    <view class="form-item">
      <text class="form-label">WiFi名称</text>
      <input class="form-input" placeholder="输入WiFi名称" value="{{wifiConfig.ssid}}" 
        data-field="ssid" bindinput="onWifiInput" />
    </view>
    <view class="form-item">
      <text class="form-label">密码</text>
      <input class="form-input" placeholder="输入WiFi密码" password value="{{wifiConfig.password}}" 
        data-field="password" bindinput="onWifiInput" />
    </view>
    <view class="form-item">
      <text class="form-label">加密方式</text>
      <picker range="{{['WPA', 'WEP', '无']}}" value="{{wifiConfig.encryption === 'WPA' ? 0 : wifiConfig.encryption === 'WEP' ? 1 : 2}}">
        <view class="form-input picker">{{wifiConfig.encryption}}</view>
      </picker>
    </view>
  </view>

  <!-- 设置 -->
  <view class="settings-row">
    <view class="setting-item">
      <text class="setting-label">尺寸</text>
      <picker range="{{sizeOptions}}" value="{{sizeIndex}}" bindchange="onSizeChange">
        <view class="setting-val">{{sizeOptions[sizeIndex]}}px</view>
      </picker>
    </view>
    <view class="setting-item">
      <text class="setting-label">前景色</text>
      <input class="color-input" type="text" value="{{fgColor}}" data-field="fgColor" bindinput="onColorChange" />
    </view>
    <view class="setting-item">
      <text class="setting-label">背景色</text>
      <input class="color-input" type="text" value="{{bgColor}}" data-field="bgColor" bindinput="onColorChange" />
    </view>
  </view>

  <button class="btn-generate" bindtap="generateQR">生成二维码</button>

  <view class="result-section" wx:if="{{generated}}">
    <view class="qr-preview" style="width:{{qrSize}}px;height:{{qrSize}}px;background:{{bgColor}};">
      <text class="qr-placeholder" style="color:{{fgColor}};">QR</text>
    </view>
    <button class="btn-save" bindtap="saveQR">保存到相册</button>
  </view>
</view>
