<view class="page">
  <view class="card">
    <view class="card-title">📝 输入文本</view>
    <textarea 
      class="input-area" 
      placeholder="请输入要检测的文本内容..." 
      value="{{inputText}}"
      bindinput="onInput"
      maxlength="5000"
    />
    <view class="input-footer">
      <text class="char-count">{{inputText.length}} / 5000</text>
      <button class="btn-clear" size="mini" bindtap="clear">清空</button>
    </view>
  </view>

  <button class="btn-check" bindtap="checkSensitive" loading="{{loading}}">
    🔍 开始检测
  </button>

  <!-- 检测结果 -->
  <view wx:if="{{checked && result}}" class="result-card">
    <view class="result-header">
      <text class="result-score {{result.level}}">{{result.score}}分</text>
      <text class="result-level {{result.level}}">{{result.levelText}}</text>
    </view>

    <view class="score-bar">
      <view class="score-fill {{result.level}}" style="width: {{result.score}}%"></view>
    </view>

    <view class="result-stats">
      <view class="stat-item">
        <text class="stat-num">{{result.charCount}}</text>
        <text class="stat-label">字符数</text>
      </view>
      <view class="stat-item">
        <text class="stat-num danger">{{result.found.length}}</text>
        <text class="stat-label">敏感词</text>
      </view>
    </view>

    <view wx:if="{{result.found.length > 0}}" class="sensitive-words">
      <view class="sensitive-title">🔴 发现的敏感词：</view>
      <view class="word-tags">
        <text class="word-tag" wx:for="{{result.found}}" wx:key="index">{{item}}</text>
      </view>
    </view>

    <view wx:if="{{result.found.length > 0}}" class="clean-text">
      <view class="clean-title">✨ 净化后的文本：</view>
      <view class="clean-content">{{result.cleanText}}</view>
      <button class="btn-copy" bindtap="copyResult">📋 复制净化文本</button>
    </view>

    <view wx:if="{{result.found.length === 0}}" class="safe-tip">
      🎉 未检测到敏感词，内容可以正常使用！
    </view>
  </view>
</view>
