/* pages/history/history.wxss */
.page { padding: 24rpx; background: #F8F9FA; min-height: 100vh; }
.header-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.header-title { font-size: 26rpx; color: #999; }
.clear-btn { font-size: 26rpx; color: #E74C3C; }
.empty-state { text-align: center; padding: 120rpx 0; }
.empty-icon { font-size: 120rpx; display: block; margin-bottom: 24rpx; }
.empty-text { font-size: 32rpx; color: #666; display: block; margin-bottom: 12rpx; }
.empty-hint { font-size: 24rpx; color: #999; }
.history-list { display: flex; flex-direction: column; gap: 16rpx; }
.history-item { background: #FFF; border-radius: 20rpx; padding: 24rpx; display: flex; align-items: center; }
.item-left { margin-right: 20rpx; }
.item-emoji { font-size: 48rpx; }
.item-content { flex: 1; display: flex; flex-direction: column; }
.item-name { font-size: 28rpx; color: #2D3436; margin-bottom: 8rpx; }
.item-time { font-size: 22rpx; color: #999; }
