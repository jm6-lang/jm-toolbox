/* pages/meme/meme.wxss */
.page { padding: 24rpx; background: #F8F9FA; min-height: 100vh; }
.hero-card { background: linear-gradient(135deg, #F39C12, #FDCB6E); border-radius: 32rpx; padding: 60rpx 40rpx; text-align: center; margin-bottom: 32rpx; }
.hero-emoji { font-size: 160rpx; margin-bottom: 16rpx; }
.hero-placeholder { font-size: 120rpx; opacity: 0.5; }
.hero-label { font-size: 40rpx; font-weight: 700; color: #FFF; text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2); }
.hero-hint { font-size: 26rpx; color: rgba(255,255,255,0.8); }
.btn-random { background: linear-gradient(135deg, #F39C12, #E74C3C); color: #FFF; border-radius: 60rpx; padding: 32rpx; font-size: 32rpx; font-weight: 700; border: none; box-shadow: 0 8rpx 32rpx rgba(243, 156, 18, 0.5); margin-bottom: 24rpx; }
.btn-random::after { border: none; }
.action-row { display: flex; gap: 20rpx; margin-bottom: 24rpx; }
.btn-copy, .btn-share { flex: 1; padding: 24rpx; border-radius: 50rpx; font-size: 26rpx; font-weight: 600; text-align: center; border: none; }
.btn-copy { background: #FFF; color: #F39C12; }
.btn-share { background: #FFF; color: #666; }
.btn-copy::after, .btn-share::after { border: none; }
.card { background: #FFF; border-radius: 24rpx; padding: 30rpx; }
.card-title { font-size: 28rpx; font-weight: 600; color: #2D3436; margin-bottom: 20rpx; }
.history-list { display: flex; flex-direction: column; gap: 16rpx; }
.history-item { display: flex; align-items: center; background: #F8F9FA; border-radius: 16rpx; padding: 20rpx 24rpx; }
.history-emoji { font-size: 48rpx; margin-right: 16rpx; }
.history-label { flex: 1; font-size: 26rpx; color: #2D3436; }
.history-time { font-size: 20rpx; color: #999; }
