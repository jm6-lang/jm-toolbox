<view class="page">
  <view class="logo-card">
    <view class="logo-icon">🧰</view>
    <text class="logo-name">JM的工具箱</text>
    <text class="logo-slogan">永久免费 · 无限使用</text>
    <view class="version-tag">v{{version}}</view>
  </view>

  <view class="card">
    <view class="card-title">✨ 功能介绍</view>
    <view class="feature-list">
      <view class="feature-item" wx:for="{{features}}" wx:key="index">
        <text class="feature-icon">{{item.icon}}</text>
        <text class="feature-text">{{item.text}}</text>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="card-title">📌 更新说明</view>
    <view class="update-item">
      <text class="update-version">v{{version}}</text>
      <text class="update-date">{{updateTime}}</text>
    </view>
    <text class="update-desc">全新上线，功能持续更新中</text>
  </view>

  <view class="card">
    <view class="card-title">💡 使用提示</view>
    <text class="tip-text">• 遇到问题可尝试重启小程序\n• 图片处理需要网络环境\n• 建议收藏以便随时使用</text>
  </view>

  <button class="btn-share" open-type="share">🔗 分享给好友</button>
</view>
