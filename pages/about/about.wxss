/* pages/about/about.wxss */
.page { padding: 24rpx; background: #F8F9FA; min-height: 100vh; }
.logo-card { background: linear-gradient(135deg, #6C5CE7, #A29BFE); border-radius: 32rpx; padding: 60rpx 40rpx; text-align: center; margin-bottom: 24rpx; }
.logo-icon { font-size: 100rpx; margin-bottom: 16rpx; }
.logo-name { font-size: 40rpx; font-weight: 700; color: #FFF; display: block; margin-bottom: 8rpx; }
.logo-slogan { font-size: 24rpx; color: rgba(255,255,255,0.8); display: block; margin-bottom: 20rpx; }
.version-tag { display: inline-block; background: rgba(255,255,255,0.25); color: #FFF; font-size: 22rpx; padding: 6rpx 20rpx; border-radius: 20rpx; }
.card { background: #FFF; border-radius: 24rpx; padding: 30rpx; margin-bottom: 24rpx; }
.card-title { font-size: 30rpx; font-weight: 600; color: #2D3436; margin-bottom: 20rpx; }
.feature-list { display: flex; flex-direction: column; gap: 16rpx; }
.feature-item { display: flex; align-items: center; }
.feature-icon { font-size: 32rpx; margin-right: 16rpx; }
.feature-text { font-size: 26rpx; color: #666; }
.update-item { display: flex; align-items: center; gap: 16rpx; margin-bottom: 8rpx; }
.update-version { font-size: 26rpx; font-weight: 600; color: #6C5CE7; }
.update-date { font-size: 22rpx; color: #999; }
.update-desc { font-size: 24rpx; color: #999; }
.tip-text { font-size: 24rpx; color: #666; line-height: 2; }
.btn-share { background: linear-gradient(135deg, #6C5CE7, #A29BFE); color: #FFF; border-radius: 50rpx; padding: 28rpx; font-size: 30rpx; font-weight: 600; border: none; box-shadow: 0 6rpx 24rpx rgba(108, 92, 231, 0.4); }
.btn-share::after { border: none; }
