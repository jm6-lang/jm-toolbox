.page { padding: 24rpx; background: #f5f6fa; min-height: 100vh; }
.header { text-align: center; padding: 24rpx 0; }
.header-title { font-size: 36rpx; font-weight: 700; color: #2d3436; display: block; }
.header-sub { font-size: 24rpx; color: #999; margin-top: 8rpx; display: block; }
.chain-display { background: #fff; border-radius: 16rpx; padding: 28rpx; margin-bottom: 24rpx; display: flex; align-items: center; gap: 16rpx; flex-wrap: wrap; }
.chain-tags { display: flex; gap: 8rpx; flex-wrap: wrap; flex: 1; }
.chain-tag { background: #f0eeff; color: #6C5CE7; font-size: 26rpx; padding: 8rpx 16rpx; border-radius: 8rpx; }
.chain-arrow { font-size: 32rpx; color: #999; }
.chain-result { font-size: 36rpx; font-weight: 700; color: #6C5CE7; }
.empty-hint { text-align: center; padding: 40rpx 0; }
.empty-icon { font-size: 64rpx; display: block; }
.empty-text { font-size: 26rpx; color: #999; margin-top: 8rpx; display: block; }
.keypad { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 24rpx; }
.key-item { width: calc(25% - 12rpx); background: #fff; border-radius: 12rpx; padding: 20rpx 0; text-align: center; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.key-label { font-size: 36rpx; font-weight: 600; color: #2d3436; display: block; }
.key-desc { font-size: 22rpx; color: #999; margin-top: 4rpx; display: block; }
.btn-row { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.btn-undo { flex: 1; background: #f0f0f0; color: #333; border-radius: 12rpx; font-size: 28rpx; padding: 20rpx; }
.btn-reset { flex: 1; background: #e74c3c; color: #fff; border-radius: 12rpx; font-size: 28rpx; padding: 20rpx; }
.tips { background: #fff; border-radius: 16rpx; padding: 24rpx; }
.tips-title { font-size: 28rpx; font-weight: 600; color: #333; display: block; margin-bottom: 12rpx; }
.tips-item { font-size: 26rpx; color: #666; display: block; line-height: 2; }
