.page { padding: 24rpx; background: #f5f6fa; min-height: 100vh; }
.tabs { display: flex; background: #fff; border-radius: 16rpx; margin-bottom: 24rpx; overflow: hidden; }
.tab { flex: 1; text-align: center; padding: 20rpx 0; font-size: 28rpx; color: #666; }
.tab-active { color: #6C5CE7; font-weight: 600; background: #f0eeff; }
.card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 24rpx; }
.form-item { display: flex; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.form-item:last-child { border: none; }
.form-label { width: 160rpx; font-size: 28rpx; color: #333; }
.form-input { flex: 1; font-size: 28rpx; text-align: right; }
.form-unit { width: 60rpx; font-size: 26rpx; color: #999; text-align: right; }
.picker { color: #333; }
.btn-calc { background: #6C5CE7; color: #fff; border-radius: 16rpx; font-size: 32rpx; padding: 24rpx; margin-bottom: 24rpx; }
.result-card { background: linear-gradient(135deg, #6C5CE7, #a29bfe); border-radius: 16rpx; padding: 32rpx; color: #fff; }
.result-title { font-size: 28rpx; opacity: 0.8; margin-bottom: 16rpx; }
.result-main { text-align: center; margin-bottom: 24rpx; }
.result-label { font-size: 26rpx; opacity: 0.8; display: block; }
.result-value { font-size: 56rpx; font-weight: 700; }
.result-row { display: flex; justify-content: space-around; padding: 20rpx 0; border-top: 1rpx solid rgba(255,255,255,0.2); }
.result-item { text-align: center; }
.result-num { font-size: 30rpx; font-weight: 600; display: block; margin-top: 4rpx; }
.result-detail { margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid rgba(255,255,255,0.2); }
.detail-line { font-size: 24rpx; opacity: 0.8; display: block; line-height: 1.8; }
